DATABASE_URL=postgres://...
JWT_SECRET=replace_with_a_long_random_secret
PUBLIC_BASE_URL=https://your-site.netlify.app

# Google Gmail + People API (primary mailbox + contacts lane)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Optional override. If blank, the app uses ${PUBLIC_BASE_URL}/.netlify/functions/google-oauth-callback
GOOGLE_OAUTH_REDIRECT_URI=
# Optional separate secret for encrypting stored Google tokens. If blank, JWT_SECRET is used to derive the cipher key.
GOOGLE_TOKEN_ENCRYPTION_KEY=replace_with_another_long_random_secret

# Gmail push watch + Pub/Sub webhook
GMAIL_PUBSUB_TOPIC_NAME=projects/your-google-project-id/topics/gmail-mailbox-events
GMAIL_WATCH_LABEL_IDS=INBOX
GMAIL_WATCH_LABEL_FILTER_BEHAVIOR=INCLUDE
# Optional override. If blank, the app uses ${PUBLIC_BASE_URL}/.netlify/functions/gmail-push-webhook
GMAIL_PUBSUB_AUDIENCE=
# Strongly recommended when using push-subscription authentication.
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=your-pubsub-push-service-account@your-google-project-id.iam.gserviceaccount.com
# Set to false only if you intentionally create an unauthenticated push subscription.
GMAIL_PUBSUB_REQUIRE_AUTH=true

# Optional legacy/fallback send lane
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
NOTIFY_FROM_EMAIL=alerts@yourdomain.com
INBOUND_DOMAIN=mail.yourdomain.com
INBOUND_PROVIDER=resend
MAIL_FROM_FALLBACK_NAME=SkyeEmail
MAILBOX_REPLY_TO_MODE=mailbox
AI_MONTHLY_CAP_CENTS=5000
