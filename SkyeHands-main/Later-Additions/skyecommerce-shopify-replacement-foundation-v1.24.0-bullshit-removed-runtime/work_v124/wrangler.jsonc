{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skyecommerce-shopify-replacement-foundation",
  "main": "src/index.js",
  "compatibility_date": "2026-04-15",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "skyecommerce-foundation",
      "database_id": "REPLACE_ME"
    }
  ]
}
