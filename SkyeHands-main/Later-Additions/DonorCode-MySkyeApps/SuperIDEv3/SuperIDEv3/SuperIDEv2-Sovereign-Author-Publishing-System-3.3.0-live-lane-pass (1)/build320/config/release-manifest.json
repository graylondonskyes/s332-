{
  "canonical_release_roots": [
    "app",
    "scripts",
    "config",
    "platform",
    "fixtures",
    "smoke",
    "docs/HARDENING_TODO.md",
    "package.json",
    "README.md",
    "server"
  ],
  "protected_app_targets": [
    "app/index.html",
    "app/styles.css",
    "app/app.js",
    "app/manifest.webmanifest",
    "app/sw.js",
    "platform/export-import.js",
    "platform/publishing.js",
    "platform/commerce.js",
    "platform/catalog.js",
    "platform/release-history.js",
    "platform/local-auth.js",
    "platform/truth-boundaries.js",
    "platform/runtime-state.js",
    "platform/server-auth.js",
    "platform/payment-gateways.js",
    "platform/submission-adapters.js",
    "server/create-server.js"
  ],
  "excluded_roots": [
    "dist",
    "node_modules",
    "artifacts/legacy-archive/raw",
    ".git"
  ],
  "banned_provider_strings": [
    "api.openai.com",
    "anthropic.com",
    "generativelanguage.googleapis.com",
    "claude-",
    "gpt-",
    "gemini-",
    "anthropic",
    "openai",
    "claude",
    "gemini"
  ],
  "banned_external_endpoints": [
    "https://api.openai.com",
    "https://api.anthropic.com",
    "https://generativelanguage.googleapis.com"
  ],
  "required_secure_defaults": {
    "openGate": false,
    "requireLocalSession": true,
    "sessionTtlMinutes": 15,
    "workspaceExportRequiresPassphrase": true,
    "authMode": "server-token-capable",
    "paymentMode": "stripe-adapter-capable",
    "submissionMode": "submission-adapter-capable"
  }
}
