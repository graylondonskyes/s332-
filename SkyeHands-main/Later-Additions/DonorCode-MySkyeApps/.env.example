# WebPile Pro Enterprise (Fortune 500 patch) — Netlify Environment Variables

# REQUIRED: Neon connection string (from Neon dashboard)
NEON_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# REQUIRED: Session signing secret (generate a long random string)
APP_JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# OPTIONAL: Public base URL used for email verification/reset links.
# If omitted, the API will try to use the request Origin/Host.
APP_BASE_URL="https://YOUR-SITE.netlify.app"

# OPTIONAL: CORS allowlist (comma-separated). Supports wildcards like https://*.netlify.app
# If omitted, origins are allowed (dev-friendly, less strict).
ORIGIN_ALLOWLIST="https://YOUR-SITE.netlify.app,https://YOURDOMAIN.com"

# Rate limiting
# "db" = distributed (Postgres-backed, recommended); "memory" = best-effort per instance.
RATE_LIMIT_MODE="db"
RATE_LIMIT_PER_MINUTE="120"
AUTH_RATE_LIMIT_PER_MINUTE="30"

# Auth hardening
LOGIN_MAX_ATTEMPTS="10"        # failed attempts before lock
LOGIN_LOCK_MINUTES="15"        # lock duration
REQUIRE_EMAIL_VERIFICATION="false"  # when true, blocks project writes until verified

# Email behavior
# "outbox" queues emails into Neon table email_outbox (recommended for prod integration).
# "dev" includes tokens/links in API responses to speed up local testing.
MAIL_MODE="outbox"

# OPTIONAL: For local http testing only
COOKIE_SECURE="true"


# ---- SBOM signing (CI)
# Ed25519 PEM keys (used in CI to sign and verify sbom.cdx.json)
SBOM_SIGNING_PRIVATE_KEY_PEM=
SBOM_SIGNING_PUBLIC_KEY_PEM=


# ---- Environment split
# production | staging | preview
APP_ENV=production

# Optional: separate Neon DB for staging/preview (recommended)
NEON_DATABASE_URL_STAGING=
NEON_DATABASE_URL_PREVIEW=

# ---- OIDC strictness
# Require id_token and verify signature/claims against JWKS
OIDC_REQUIRE_ID_TOKEN=true
# Allowed id_token signing algorithms (comma-separated)
OIDC_ALG_ALLOWLIST=RS256,ES256


# ---- RLS (optional hard isolation at DB)
ENABLE_RLS=false

# ---- SAML (optional)
SAML_ENABLED=false

# ---- SIEM delivery
SIEM_ENABLED=true
SIEM_MAX_BATCH=100
SIEM_LOCK_SECONDS=30
SIEM_RETRY_BASE_SECONDS=15

# ---- Release signing (GitHub Actions secrets)
RELEASE_SIGNING_PRIVATE_KEY_PEM=
RELEASE_SIGNING_PUBLIC_KEY_PEM=


# ---- Direct OpenAI (optional fallback if you do not save a key in the app settings)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com"
OPENAI_DEFAULT_MODEL="gpt-4o-mini"
OPENAI_AGENT_MAX_STEPS="30"
