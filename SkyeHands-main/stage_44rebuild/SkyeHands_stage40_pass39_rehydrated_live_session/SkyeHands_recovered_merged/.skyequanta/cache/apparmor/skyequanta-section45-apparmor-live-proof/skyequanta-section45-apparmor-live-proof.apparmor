abi <abi/4.0>,
include <tunables/global>

profile skyequanta-section45-apparmor-live-proof flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  /usr/bin/** mr,
  /usr/local/bin/** mr,
  /bin/** mr,
  /lib/** mr,
  /lib64/** mr,
  /etc/ld.so.cache r,
  /tmp/skyehands32/dist/section45/apparmor-workspace/** rwk,
  deny network raw,
  deny network packet,
  deny /proc/*/mem rw,
  deny /sys/** rwklx,
}
