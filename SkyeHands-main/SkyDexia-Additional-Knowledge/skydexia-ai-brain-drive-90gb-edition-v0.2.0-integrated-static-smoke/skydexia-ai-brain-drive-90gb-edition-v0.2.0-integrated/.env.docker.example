# Copy this to .env.docker and edit it.

# External model vault root.
# This folder must contain or create an `ollama/` folder.
#
# Chromebook/Linux example:
# SKYDEXIA_MODEL_ROOT=/mnt/chromeos/removable/SKYEDEXIA90/SkyeDexia90GB/SkyeAIModels
#
# Normal Linux example:
# SKYDEXIA_MODEL_ROOT=/media/$USER/SKYEDEXIA90/SkyeDexia90GB/SkyeAIModels
#
# Local test example:
# SKYDEXIA_MODEL_ROOT=./.skydexia-models

SKYDEXIA_MODEL_ROOT=./.skydexia-models

# Default model used by the app router.
SKYDEXIA_DEFAULT_MODEL=qwen2.5-coder:7b
