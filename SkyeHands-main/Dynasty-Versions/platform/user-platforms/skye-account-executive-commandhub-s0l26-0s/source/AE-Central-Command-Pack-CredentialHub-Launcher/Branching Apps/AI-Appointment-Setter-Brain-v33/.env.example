APP_ENV=development
HOST=127.0.0.1
PORT=8018

APP_BRAND=Skyes Appointment Setter
APP_SUPPORT_EMAIL=support@example.com
APP_SUPPORT_PHONE=(555) 010-2026
APP_BASE_URL=http://127.0.0.1:8018

# Bootstrap accounts are forced to rotate passwords on first login.
ADMIN_BOOTSTRAP_ORG_ID=1
ADMIN_BOOTSTRAP_EMAIL=owner@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-now
ADMIN_BOOTSTRAP_NAME=Owner Desk
MANAGER_BOOTSTRAP_EMAIL=ops@example.com
MANAGER_BOOTSTRAP_PASSWORD=change-me-now
VIEWER_BOOTSTRAP_EMAIL=viewer@example.com
VIEWER_BOOTSTRAP_PASSWORD=change-me-now

ADMIN_SESSION_TTL_HOURS=12
ADMIN_LOGIN_LOCKOUT_THRESHOLD=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15
SESSION_COOKIE_SECURE=false

VOICE_FROM_NUMBER=+14805550100
VOICE_WEBHOOK_URL=
VOICE_WEBHOOK_SECRET=replace-with-a-long-random-secret

SMS_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
SMS_INBOUND_SECRET=replace-with-a-long-random-secret
EMAIL_INBOUND_SECRET=replace-with-a-long-random-secret

# Optional direct SMTP email delivery. Leave blank if using EMAIL_WEBHOOK_URL instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ACCOUNT_EMAIL=
GOOGLE_CALENDAR_API_BASE=https://www.googleapis.com/calendar/v3

MICROSOFT_CALENDAR_ACCESS_TOKEN=
MICROSOFT_CALENDAR_ID=primary
MICROSOFT_CALENDAR_ACCOUNT_EMAIL=
MICROSOFT_GRAPH_BASE=https://graph.microsoft.com/v1.0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
