PORT=4177
NODE_ENV=development
PUBLIC_BASE_URL=<runtime-base-url>
DATABASE_DRIVER=local-json
DATABASE_PATH=./data/skyeroutex-db.json
# Postgres production path:
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/skyeroutex
# PSQL_BIN=psql
# WORKFORCE_DOCUMENT_ID=default
STORAGE_DRIVER=local-json
MEDIA_ROOT=./data/proof-media
EXPORT_ROOT=./data/exports
# For S3/R2-compatible proof media and export packets:
# STORAGE_DRIVER=s3-compatible
# STORAGE_DRIVER=r2
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_BUCKET=skyeroutex-proof
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=replace_me
# STORAGE_SECRET_ACCESS_KEY=replace_me
# STORAGE_PREFIX=workforce-command
# STORAGE_FORCE_PATH_STYLE=1
SKYE_ADMIN_EMAIL=
SKYE_ADMIN_PASSWORD=
SKYE_REQUIRE_CSRF=0
COOKIE_SECURE=0
MAX_BODY_BYTES=1048576
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_MS=60000
# Local development/proof profile. Leave enabled for `npm run smoke:*` and local panel proofing.
# Production should start from `.env.production.example`, keep this at 0, and configure non-proof providers.
SKYE_ALLOW_LOCAL_PROOF_SERVICES=1
PAYMENT_PROVIDER=ledger-only
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_live_or_test_key
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# STRIPE_CURRENCY=usd
# STRIPE_CAPTURE_METHOD=manual
# PAYMENT_PROVIDER=payment-webhook
# PAYMENT_WEBHOOK_ENDPOINT=<provider-webhook-base>/payment
# PAYMENT_WEBHOOK_SIGNING_SECRET=replace-with-at-least-16-chars
NOTIFICATION_PROVIDER=in-app-ledger
# NOTIFICATION_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=replace_me
# TWILIO_FROM_NUMBER=+15550000001
# TWILIO_DEFAULT_TO=+15550000002
# NOTIFICATION_PROVIDER=notification-webhook
# NOTIFICATION_WEBHOOK_ENDPOINT=<provider-webhook-base>/notification
# NOTIFICATION_WEBHOOK_SIGNING_SECRET=replace-with-at-least-16-chars
ROUTE_INTELLIGENCE_PROVIDER=route-structure-only
# ROUTE_INTELLIGENCE_PROVIDER=mapbox
# MAPBOX_ACCESS_TOKEN=replace_me
# MAPBOX_PROFILE=driving
IDENTITY_COMPLIANCE_PROVIDER=local-attestation-ledger
# IDENTITY_COMPLIANCE_PROVIDER=checkr
# CHECKR_API_KEY=replace_me
# CHECKR_PACKAGE=driver_pro
# CHECKR_WORK_LOCATION=US
# CHECKR_WEBHOOK_SECRET=replace_me
# IDENTITY_COMPLIANCE_PROVIDER=compliance-webhook
# COMPLIANCE_WEBHOOK_ENDPOINT=<provider-webhook-base>/compliance
# COMPLIANCE_WEBHOOK_SIGNING_SECRET=replace-with-at-least-16-chars
SKYEHANDS_RUNTIME_PROVIDER=standalone-local-events
# SKYEHANDS_RUNTIME_PROVIDER=skyehands-runtime-webhook
# SKYEHANDS_RUNTIME_WEBHOOK_ENDPOINT=<provider-webhook-base>/runtime
# SKYEHANDS_RUNTIME_WEBHOOK_SIGNING_SECRET=replace-with-at-least-16-chars
# SKYEHANDS_RUNTIME_PROVIDER=skyehands-runtime-bus
# SKYEHANDS_RUNTIME_BUS_DIR=../../skyehands_runtime_control/.skyequanta
# SKYEHANDS_RUNTIME_SOURCE_PLATFORM=skyeroutex-workforce-command
# SKYEHANDS_RUNTIME_WORKSPACE_ID=skyeroutex-workforce-command
