PORT=4177
NODE_ENV=production
PUBLIC_BASE_URL=https://skyeroutex.example

DATABASE_DRIVER=local-json
DATABASE_PATH=/var/lib/skyeroutex-workforce-command/skyeroutex-db.json
# Postgres production path:
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/skyeroutex
# PSQL_BIN=psql
# WORKFORCE_DOCUMENT_ID=default
STORAGE_DRIVER=local-json
MEDIA_ROOT=/var/lib/skyeroutex-workforce-command/proof-media
EXPORT_ROOT=/var/lib/skyeroutex-workforce-command/exports
# For S3/R2-compatible proof media and export packets:
# STORAGE_DRIVER=s3-compatible
# STORAGE_DRIVER=r2
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_BUCKET=skyeroutex-proof
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=replace_me
# STORAGE_SECRET_ACCESS_KEY=replace_me
# STORAGE_PREFIX=workforce-command
# STORAGE_FORCE_PATH_STYLE=1

SKYE_ADMIN_EMAIL=house-command@internal.invalid
SKYE_ADMIN_PASSWORD=REPLACE_WITH_A_LONG_UNIQUE_PASSWORD_123
SKYE_REQUIRE_CSRF=1
COOKIE_SECURE=1
MAX_BODY_BYTES=1048576
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_MS=60000
SKYE_ALLOW_LOCAL_PROOF_SERVICES=0

PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_CURRENCY=usd
STRIPE_CAPTURE_METHOD=manual
# PAYMENT_PROVIDER=payment-webhook
# PAYMENT_WEBHOOK_ENDPOINT=https://example.invalid/skyeroutex/payment
# PAYMENT_WEBHOOK_SIGNING_SECRET=REPLACE_WITH_PAYMENT_WEBHOOK_SIGNING_SECRET
NOTIFICATION_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+15550000001
TWILIO_DEFAULT_TO=+15550000002
# NOTIFICATION_PROVIDER=notification-webhook
# NOTIFICATION_WEBHOOK_ENDPOINT=https://example.invalid/skyeroutex/notification
# NOTIFICATION_WEBHOOK_SIGNING_SECRET=REPLACE_WITH_NOTIFICATION_WEBHOOK_SIGNING_SECRET
ROUTE_INTELLIGENCE_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=REPLACE_WITH_MAPBOX_ACCESS_TOKEN
MAPBOX_PROFILE=driving
IDENTITY_COMPLIANCE_PROVIDER=checkr
CHECKR_API_KEY=REPLACE_WITH_CHECKR_API_KEY
CHECKR_PACKAGE=driver_pro
CHECKR_WORK_LOCATION=US
CHECKR_WEBHOOK_SECRET=REPLACE_WITH_CHECKR_WEBHOOK_SECRET
# IDENTITY_COMPLIANCE_PROVIDER=compliance-webhook
# COMPLIANCE_WEBHOOK_ENDPOINT=https://example.invalid/skyeroutex/compliance
# COMPLIANCE_WEBHOOK_SIGNING_SECRET=REPLACE_WITH_COMPLIANCE_WEBHOOK_SIGNING_SECRET
SKYEHANDS_RUNTIME_PROVIDER=skyehands-runtime-bus
# SKYEHANDS_RUNTIME_PROVIDER=skyehands-runtime-webhook
# SKYEHANDS_RUNTIME_WEBHOOK_ENDPOINT=https://example.invalid/skyeroutex/runtime
# SKYEHANDS_RUNTIME_WEBHOOK_SIGNING_SECRET=REPLACE_WITH_RUNTIME_WEBHOOK_SIGNING_SECRET
SKYEHANDS_RUNTIME_BUS_DIR=../../skyehands_runtime_control/.skyequanta
SKYEHANDS_RUNTIME_SOURCE_PLATFORM=skyeroutex-workforce-command
SKYEHANDS_RUNTIME_WORKSPACE_ID=skyeroutex-workforce-command
