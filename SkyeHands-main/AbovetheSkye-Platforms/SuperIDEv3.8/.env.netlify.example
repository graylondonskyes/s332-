# Netlify site / Netlify Functions environment variables
# Copy the values you actually use into Netlify site settings.

# Required for the secured main runtime
NEON_DATABASE_URL=
WORKER_RUNNER_URL=
RUNNER_SHARED_SECRET=
KAIXU_GATEWAY_ENDPOINT=
KAIXU_APP_TOKEN=
SKYGATEFS13_ORIGIN=
SKYGATE_EVENT_MIRROR_SECRET=
SKYGATE_SOURCE_APP=superidev3-8
SUPERIDE_ALLOW_LEGACY_LOCAL_SESSION_AUTH=false

# Optional gateway labels / hardening
KAIXU_GATEWAY_PROVIDER=
KAIXU_GATEWAY_MODEL=
TOKEN_MASTER_SEQUENCE=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional mail / onboarding delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
SKYE_MAIL_FROM=
RESEND_API_KEY=
MAIL_INGEST_SECRET=

# SuperIDEv3 server auth, payment, and submission lanes
SKYE_RUNTIME_MODE=production
SKYE_AUTH_SECRET=
SKYE_OPERATOR_PASSPHRASE=
SKYE_OPERATOR_SALT=
SKYE_OPERATOR=Skyes Over London
SKYE_ORG=SOLEnterprises
SKYE_PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com
SKYE_RUNTIME_STATE_PATH=
SKYE_PORTAL_AUTOMATION_ENABLE=false
SKYE_PORTAL_ARTIFACT_DIR=
SKYE_SUBMIT_APPLE_URL=
SKYE_SUBMIT_APPLE_MODE=portal
SKYE_SUBMIT_APPLE_TOKEN=
SKYE_SUBMIT_APPLE_PARTNER_ID=
SKYE_SUBMIT_KOBO_URL=
SKYE_SUBMIT_KOBO_MODE=portal
SKYE_SUBMIT_KOBO_KEY=
SKYE_SUBMIT_KOBO_SECRET=
SKYE_SUBMIT_KDP_EBOOK_URL=
SKYE_SUBMIT_KDP_EBOOK_MODE=portal
SKYE_SUBMIT_KDP_PRINT_URL=
SKYE_SUBMIT_KDP_PRINT_MODE=portal
SKYE_SUBMIT_KDP_KEY=
SKYE_SUBMIT_KDP_SECRET=
SKYE_SUBMISSION_AUTH_TOKEN=

# Optional frontend build-time metadata passed through Netlify build env
VITE_WORKER_RUNNER_URL=
VITE_DEFAULT_WS_ID=primary-workspace
VITE_SITE_BASE_URL=
VITE_APP_VERSION=
VITE_GIT_SHA=
VITE_BUILD_TIME=
