# Copy to .env.docker before running docker compose.

# Docker build and local port wiring
NODE_VERSION=22.14.0
VITE_DEV_PORT=5173
NETLIFY_DEV_PORT=8888
WORKER_DEV_PORT=8787
SITE_PORT=8080
POSTGRES_PORT=5432
SQL_HTTP_PORT=5540
ADMINER_PORT=8081
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Local database defaults
POSTGRES_DB=superidev2
POSTGRES_USER=superide
POSTGRES_PASSWORD=superide-local-only

# Netlify site / Netlify Functions environment variables
NEON_DATABASE_URL=http://db-http:5540/sql
WORKER_RUNNER_URL=http://worker:8787
RUNNER_SHARED_SECRET=
KAIXU_GATEWAY_ENDPOINT=
KAIXU_APP_TOKEN=
SKYGATEFS13_ORIGIN=http://host.docker.internal:8889
SKYGATE_EVENT_MIRROR_SECRET=
SKYGATE_SOURCE_APP=superidev3-8
SUPERIDE_ALLOW_LEGACY_LOCAL_SESSION_AUTH=false

# Optional gateway labels / hardening
KAIXU_GATEWAY_PROVIDER=
KAIXU_GATEWAY_MODEL=
TOKEN_MASTER_SEQUENCE=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional mail / onboarding delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
SKYE_MAIL_FROM=
RESEND_API_KEY=
MAIL_INGEST_SECRET=

# SuperIDEv3 server auth, payment, and submission lanes
SKYE_RUNTIME_MODE=development
SKYE_AUTH_SECRET=
SKYE_OPERATOR_PASSPHRASE=sovereign-build-passphrase
SKYE_OPERATOR_SALT=fixed-testsalt-fixed
SKYE_OPERATOR=Skyes Over London
SKYE_ORG=SOLEnterprises
SKYE_PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com
SKYE_RUNTIME_STATE_PATH=
SKYE_PORTAL_AUTOMATION_ENABLE=true
SKYE_PORTAL_ARTIFACT_DIR=
SKYE_SUBMIT_APPLE_URL=
SKYE_SUBMIT_APPLE_MODE=portal
SKYE_SUBMIT_APPLE_TOKEN=
SKYE_SUBMIT_APPLE_PARTNER_ID=
SKYE_SUBMIT_KOBO_URL=
SKYE_SUBMIT_KOBO_MODE=portal
SKYE_SUBMIT_KOBO_KEY=
SKYE_SUBMIT_KOBO_SECRET=
SKYE_SUBMIT_KDP_EBOOK_URL=
SKYE_SUBMIT_KDP_EBOOK_MODE=portal
SKYE_SUBMIT_KDP_PRINT_URL=
SKYE_SUBMIT_KDP_PRINT_MODE=portal
SKYE_SUBMIT_KDP_KEY=
SKYE_SUBMIT_KDP_SECRET=
SKYE_SUBMISSION_AUTH_TOKEN=

# Frontend build-time metadata for local containers
VITE_WORKER_RUNNER_URL=<local-dev-runner-url>
VITE_DEFAULT_WS_ID=primary-workspace
VITE_SITE_BASE_URL=<local-dev-runtime-url>
VITE_APP_VERSION=docker-local
VITE_GIT_SHA=docker-local
VITE_BUILD_TIME=
