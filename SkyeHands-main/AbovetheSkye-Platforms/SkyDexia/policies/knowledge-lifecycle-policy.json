{
  "version": 1,
  "owner": "SkyDexia",
  "knowledgeRoot": "skydexia/knowledge-base",
  "importLane": "skydexia/knowledge-base/GiftsFromtheSkyes",
  "requiredMetadata": [
    "source",
    "importedAt",
    "checksum",
    "classification",
    "compatibility",
    "qualityScore"
  ],
  "retention": {
    "policy": "immutable-import-log",
    "auditRequired": true
  },
  "continuousUpdate": {
    "required": true,
    "updateWhen": [
      "SkyeHands architecture changes",
      "SkyDexia AI brain files change",
      "AE brain or provider routing changes",
      "donor templates are imported or normalized",
      "design-vault sources or recipes change",
      "IDE surfaces or autonomous project-generation behavior changes"
    ],
    "proofCommand": "npm run skydexia:wiring-smoke",
    "wiringManifest": "SkyDexia-Additional-Knowledge/manifests/skydexia-knowledge-wiring.json"
  }
}
