{
  "product": "SkyeWebCreatorMax",
  "version": "0.1.0",
  "type": "standalone-pwa-plus-skyehands-platform-node",
  "entrypoints": [
    "landing.html",
    "index.html",
    "homepage.html",
    "offline.html"
  ],
  "runtimeFiles": [
    "js/webcreator.js",
    "js/skygate-client.js",
    "service-worker.js",
    "sw.js",
    "manifest.json",
    "manifest.webmanifest",
    "netlify.toml"
  ],
  "connectedBridge": "skyehands_runtime_control/core/webcreator/skyewebcreator-bridge.mjs",
  "platformBus": "skyehands_runtime_control/core/platform-bus/skyehands-platform-bus.mjs",
  "designVault": "design-vault/library",
  "smoke": [
    "smoke/smoke-release-checks.mjs",
    "smoke/smoke-browser.mjs",
    "smoke/smoke-production-readiness.mjs",
    "skyehands_runtime_control/scripts/smoke-skyewebcreator-bridge.mjs"
  ],
  "envContract": "config/env.contract.json",
  "gateway": {
    "canonical": "AbovetheSkye-Platforms/SkyeGateFS13",
    "eventMirror": "/.netlify/functions/platform-event-ingest",
    "aiGateway": "/.netlify/functions/gateway-chat",
    "appClientAuth": "/.netlify/functions/auth-app-login"
  },
  "productionReadinessRule": "All local smokes must pass. Production may be blocked only by missing variables in envContract.productionRequired."
}
