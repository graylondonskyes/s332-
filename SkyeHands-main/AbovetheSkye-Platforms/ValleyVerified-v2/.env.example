# ValleyVerified v2 deployment configuration

# SkyGate verification. Provide one of these in production.
SKYGATE_PUBLIC_KEY_PEM=
SKYGATE_JWKS_JSON=
SKYGATE_ISSUER=
SKYGATE_AUDIENCE=

# Local/file persistence. Production can point this at a mounted data path
# or replace the store adapter with managed persistence.
VALLEYVERIFIED_DATA_DIR=

# Payment providers are consumed through SkyGate/SkyeCards flows.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional notification dispatch providers.
DISPATCH_WEBHOOK_URL=
EMAIL_PROVIDER_API_KEY=
