DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobping?schema=public"
SESSION_COOKIE_NAME="jobping_session"
SESSION_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INTERNAL_CRON_SECRET="replace-with-a-long-random-internal-secret"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
STRIPE_PORTAL_RETURN_URL="http://localhost:3000/billing"

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Provider webhook endpoints to configure after deploy:
# Stripe webhook: /api/billing/webhook
# Twilio SMS status callback: /api/webhooks/twilio/status
# Twilio inbound SMS webhook: /api/webhooks/twilio/inbound-sms
# Twilio missed-call webhook: /api/webhooks/twilio/missed-call
# Cron target: POST /api/internal/due-messages with x-jobping-internal-secret

# Comma-separated emails allowed to open /admin support console.
JOBPING_ADMIN_EMAILS="owner@jobping.local"

# Support identity shown in Help/Walkthrough/Admin UI. Set this to your real support inbox after deploy.
JOBPING_SUPPORT_EMAIL="support@yourdomain.com"
NEXT_PUBLIC_SUPPORT_EMAIL="support@yourdomain.com"

# Usage/profit guardrails
# These can also be controlled per-account in the subscription row.
JOBPING_DEFAULT_SMS_INCLUDED=500
JOBPING_DEFAULT_SMS_OVERAGE_CENTS=4
JOBPING_DEFAULT_AI_INCLUDED=100

# Optional assistive AI lane. If absent, JobPing uses honest local fallback copy support.
OPENAI_API_KEY=
JOBPING_AI_API_KEY=
