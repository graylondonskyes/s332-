{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Dead Route Detector - SkyeVSX",
          "informationUri": "https://skyesol.netlify.app/",
          "rules": [
            {
              "id": "dead-route-reference",
              "name": "dead-route-reference",
              "shortDescription": {
                "text": "dead route reference"
              }
            },
