# SkyeHands runtime control deploy mode template
SKYEQUANTA_DEV=0
SKYEQUANTA_HOST=0.0.0.0
SKYEQUANTA_BRIDGE_PORT=3020
SKYEQUANTA_REMOTE_EXECUTOR_PORT=3320
SKYEQUANTA_IDE_PORT=3010
SKYEQUANTA_AGENT_PORT=3000
SKYEQUANTA_RUNTIME_MODE=remote-gated
SKYGATEFS13_ORIGIN=https://your-skyegate.example.com
SKYGATEFS13_GATE_TOKEN=replace-with-sub-key
SKYGATEFS13_GATE_MODEL=kaixu/deep
SKYGATE_EVENT_MIRROR_SECRET=replace-with-parent-mirror-secret
# Legacy aliases remain supported if older scripts still expect them.
SKYEQUANTA_GATE_URL=https://your-skyegate.example.com
SKYEQUANTA_GATE_TOKEN=replace-with-sub-key
SKYEQUANTA_GATE_MODEL=kaixu/deep
SKYEQUANTA_ADMIN_TOKEN=replace-me
SKYEQUANTA_MACHINE_PROFILE=standard
