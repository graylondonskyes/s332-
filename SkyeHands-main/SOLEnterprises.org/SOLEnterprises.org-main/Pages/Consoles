  <p>Exclusivity: <span class="mono">${exclus}</span></p>

  <h3>8) CANCELLATION + NO-SHOW</h3>
  <p>
    Cancellation framework: <span class="mono">${v.cancellation_terms || "Standard"}</span>.
    Where allowed by law, late cancellations or no-shows may trigger fees and/or reimbursement of documented, reasonable out-of-pocket costs.
    Any special terms must be recorded in writing.
  </p>
  ${v.special_terms ? `<p class="muted"><span class="mono">Special Terms:</span> ${v.special_terms}</p>` : ""}

  <h3>9) OWNERSHIP + BRAND SAFETY</h3>
  <p>
    Producer owns all raw footage, edits, and deliverables (excluding Model/Talent’s pre-existing IP).
    Producer/Client will not use Content for illegal purposes or in a manner that materially violates the consent/boundaries recorded above.
  </p>

  <h3>10) IDENTIFICATION + AGE CONFIRMATION</h3>
  <p>
    Model/Talent represents they are 18+ and may be asked to present government ID prior to booking.
  </p>

  <h3>11) GOVERNING LAW</h3>
  <p class="muted">
    Governing law/venue may be set by Producer for the project jurisdiction. If needed, an addendum may specify state/county and dispute resolution.
  </p>

  <h3>12) SIGNATURES</h3>
  <p>
    <strong>MODEL/TALENT:</strong> ${v.talent_legal_name || "—"} • Initials: <span class="mono">${v.talent_initials || "—"}</span><br>
    Typed Signature: <span class="mono">${v.typed_signature_name || "—"}</span> • Date: <span class="mono">${v.signature_date || "—"}</span>
  </p>
  <p class="muted">
    Producer Counter-Signature: Skyes Over London LC (authorized representative) — to be countersigned as needed.
  </p>
</div>
    `.trim();
  }

  function refreshPreview(){
    const v = values();
    const html = buildAgreementText(v);
    contractView.innerHTML = html;

    // Store snapshot (for Netlify submission)
    $("f_snapshot").value = contractView.innerText.slice(0, 9000); // keep reasonably sized

    const hasSig = Boolean(safe($("f_sig").value));
    statusText.textContent = hasSig ? "Ready" : "Draft";
  }

  /* ====== Steps navigation ====== */
  let step = 0;

  function setStep(n){
    step = Math.max(0, Math.min(4, n));
    sections.forEach(s => s.classList.toggle("active", Number(s.dataset.sec) === step));
    steps.forEach(t => t.classList.toggle("active", Number(t.dataset.step) === step));
    refreshPreview();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  document.addEventListener("click", (e) => {
    const next = e.target.closest("[data-next]");
    const prev = e.target.closest("[data-prev]");
    const st = e.target.closest(".step");
    if(next){ setStep(step+1); }
    if(prev){ setStep(step-1); }
    if(st){ setStep(Number(st.dataset.step)); }
  });

  /* ====== Contract ID + default dates ====== */
  const contractId = uid();
  $("contractId").textContent = contractId;
  $("f_contract_id").value = contractId;

  const todayISO = new Date().toISOString().slice(0,10);
  $("signature_date").value = todayISO;

  $("f_time").value = nowLocalString();

  /* ====== Autosync preview on input ====== */
  form.addEventListener("input", refreshPreview);
  form.addEventListener("change", refreshPreview);

  /* ====== Save / Load (local browser) ====== */
  const STORE_KEY = "sol_model_console_v1";

  function saveLocal(){
    const fd = new FormData(form);
    const obj = {};
    fd.forEach((val, key) => {
      if(obj[key] === undefined) obj[key] = val;
      else if(Array.isArray(obj[key])) obj[key].push(val);
      else obj[key] = [obj[key], val];
    });
    obj.__sig = $("f_sig").value || "";
    obj.__contract_id = $("f_contract_id").value;
    obj.__time = $("f_time").value;

    localStorage.setItem(STORE_KEY, JSON.stringify(obj));
    showToast("Saved", "Progress saved on this device/browser.");
  }

  function loadLocal(){
    const raw = localStorage.getItem(STORE_KEY);
    if(!raw){ showToast("Nothing saved", "No saved data found on this device."); return; }
    const obj = JSON.parse(raw);

    // Set basic inputs
    for (const [k,v] of Object.entries(obj)){
      if(k.startsWith("__")) continue;
      const els = form.querySelectorAll(`[name="${CSS.escape(k)}"]`);
      if(!els.length) continue;

      if(els[0].type === "checkbox" || els[0].type === "radio"){
        const vals = Array.isArray(v) ? v : [v];
        els.forEach(el => el.checked = vals.includes(el.value));
      } else {
        els.forEach(el => el.value = Array.isArray(v) ? v[0] : v);
      }
    }

    // Restore signature + IDs
    if(obj.__sig){ $("f_sig").value = obj.__sig; }
    if(obj.__contract_id){ $("f_contract_id").value = obj.__contract_id; $("contractId").textContent = obj.__contract_id; }
    if(obj.__time){ $("f_time").value = obj.__time; }

    showToast("Loaded", "Saved progress loaded.");
    refreshPreview();
  }

  $("btnSave").addEventListener("click", saveLocal);
  $("btnLoad").addEventListener("click", loadLocal);

  /* ====== Copy agreement text ====== */
  $("btnCopy").addEventListener("click", async () => {
    try{
      await navigator.clipboard.writeText(contractView.innerText);
      showToast("Copied", "Agreement text copied to clipboard.");
    }catch{
      showToast("Copy blocked", "Your browser blocked clipboard. Select text manually.");
    }
  });

  /* ====== Signature pad ====== */
  const canvas = $("sig");
  const ctx = canvas.getContext("2d");
  let drawing = false;
  let last = null;

  function fitCanvas(){
    const dpr = Math.max(1, Math.floor(window.devicePixelRatio || 1));
    const rect = canvas.getBoundingClientRect();
    canvas.width = Math.floor(rect.width * dpr);
    canvas.height = Math.floor(rect.height * dpr);
    ctx.setTransform(dpr,0,0,dpr,0,0);
    ctx.lineWidth = 2.4;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.strokeStyle = "rgba(246,237,255,.95)";
  }
  window.addEventListener("resize", fitCanvas);
  fitCanvas();

  function pos(e){
    const r = canvas.getBoundingClientRect();
    const x = (e.touches ? e.touches[0].clientX : e.clientX) - r.left;
    const y = (e.touches ? e.touches[0].clientY : e.clientY) - r.top;
    return {x,y};
  }

  function start(e){
    drawing = true;
    last = pos(e);
    e.preventDefault();
  }
  function move(e){
    if(!drawing) return;
    const p = pos(e);
    ctx.beginPath();
    ctx.moveTo(last.x, last.y);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    last = p;
    e.preventDefault();
  }
  function end(e){
    drawing = false;
    last = null;
    e.preventDefault();
  }

  canvas.addEventListener("mousedown", start);
  canvas.addEventListener("mousemove", move);
  window.addEventListener("mouseup", end);

  canvas.addEventListener("touchstart", start, {passive:false});
  canvas.addEventListener("touchmove", move, {passive:false});
  window.addEventListener("touchend", end, {passive:false});

  $("sigClear").addEventListener("click", () => {
    ctx.clearRect(0,0,canvas.width,canvas.height);
    $("f_sig").value = "";
    showToast("Cleared", "Signature cleared. Draw again then lock signature.");
    refreshPreview();
  });

  function signatureLooksBlank(){
    // quick heuristic: check a few pixels for alpha
    const img = ctx.getImageData(0,0,canvas.width,canvas.height).data;
    let ink = 0;
    for(let i=3;i<img.length;i+=64){
      if(img[i] > 0) { ink++; if(ink > 12) return false; }
    }
    return true;
  }

  $("sigCapture").addEventListener("click", () => {
    if(signatureLooksBlank()){
      showToast("No signature detected", "Please draw your signature before locking.");
      return;
    }
    // Create a smaller export to reduce submission size
    const exportCanvas = document.createElement("canvas");
    exportCanvas.width = 900; exportCanvas.height = 320;
    const ex = exportCanvas.getContext("2d");
    ex.fillStyle = "rgba(0,0,0,0)";
    ex.fillRect(0,0,exportCanvas.width,exportCanvas.height);
    ex.drawImage(canvas, 0, 0, exportCanvas.width, exportCanvas.height);

    const data = exportCanvas.toDataURL("image/png", 0.92);
    $("f_sig").value = data;

    showToast("Signature locked", "Signature captured into your submission.");
    refreshPreview();
  });

  /* ====== Netlify Forms submit via fetch (no redirect) ====== */
  async function encodeFormData(formEl){
    const fd = new FormData(formEl);
    const params = new URLSearchParams();
    for (const [k,v] of fd.entries()){
      params.append(k, v);
    }
    return params.toString();
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Require signature capture
    if(!safe($("f_sig").value)){
      showToast("Signature required", "Click “Lock Signature” before submitting.");
      setStep(4);
      return;
    }

    // Timestamp
    $("f_time").value = nowLocalString();
    refreshPreview();

    const body = await encodeFormData(form);

    try{
      const res = await fetch("/", {
        method: "POST",
        headers: { "Content-Type":"application/x-www-form-urlencoded" },
        body
      });

      if(!res.ok) throw new Error("Network submit failed");
      successId.textContent = $("f_contract_id").value;
      successBox.classList.add("show");
      showToast("Submitted", "Your agreement was submitted successfully.");
      // Save for user (optional)
      saveLocal();
    }catch(err){
      console.error(err);
      showToast("Submit failed", "If this continues, refresh and submit again, or contact Skyes Over London.");
    }
  });

  /* ====== PDF generation ====== */
  $("btnPDF").addEventListener("click", async () => {
    refreshPreview();
    const v = values();

    // If jsPDF not loaded yet
    if(!window.jspdf || !window.jspdf.jsPDF){
      showToast("PDF loading", "Please wait a moment and try again.");
      return;
    }

    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit:"pt", format:"letter" });

    const margin = 36;
    const maxW = 612 - margin*2;
    let y = 40;

    doc.setFont("helvetica","bold");
    doc.setFontSize(12);
    doc.text("SKYES OVER LONDON LC — MODEL RELEASE + VIDEO USAGE AGREEMENT", margin, y);
    y += 18;

    doc.setFont("helvetica","normal");
    doc.setFontSize(10);
    doc.text(`Contract ID: ${v.contract_id || "—"}     Generated: ${v.submitted_local_time || nowLocalString()}`, margin, y);
    y += 18;

    const text = contractView.innerText.replace(/\n{3,}/g,"\n\n").trim();
    const lines = doc.splitTextToSize(text, maxW);

    for(const line of lines){
      if(y > 760){
        doc.addPage();
        y = 40;
      }
      doc.text(line, margin, y);
      y += 12.5;
    }

    // Signature image (if present)
    if(v.signature_dataurl){
      try{
        if(y > 650){ doc.addPage(); y = 40; }
        doc.setFont("helvetica","bold");
        doc.text("Signature (Captured)", margin, y);
        y += 12;
        doc.addImage(v.signature_dataurl, "PNG", margin, y, 260, 92);
        y += 110;
        doc.setFont("helvetica","normal");
        doc.text(`Typed Name: ${v.typed_signature_name || "—"}    Date: ${v.signature_date || "—"}`, margin, y);
      }catch(_){}
    }

    doc.save(`${(v.contract_id || "SOL-CONTRACT")}.pdf`);
    showToast("Downloaded", "PDF saved to your device.");
  });

  /* ====== Starfield + cursor aura ====== */
  const aura = $("aura");
  window.addEventListener("mousemove", (e) => {
    aura.style.left = e.clientX + "px";
    aura.style.top = e.clientY + "px";
  });

  const c = $("starfield");
  const sctx = c.getContext("2d");
  const stars = [];
  let w=0,h=0;

  function resizeStars(){
    w = c.width = window.innerWidth;
    h = c.height = window.innerHeight;
    stars.length = 0;
    const n = Math.floor(Math.min(320, Math.max(160, (w*h)/9000)));
    for(let i=0;i<n;i++){
      stars.push({
        x: Math.random()*w,
        y: Math.random()*h,
        z: Math.random()*1 + 0.2,
        r: Math.random()*1.5 + 0.4,
        tw: Math.random()*1,
        sp: Math.random()*0.35 + 0.12
      });
    }
  }
  window.addEventListener("resize", resizeStars);
  resizeStars();

  let t=0;
  function tick(){
    t += 0.01;
    sctx.clearRect(0,0,w,h);

    // subtle nebula haze
    const g = sctx.createRadialGradient(w*0.2,h*0.2, 0, w*0.2,h*0.2, Math.max(w,h)*0.65);
    g.addColorStop(0, "rgba(168,85,247,0.10)");
    g.addColorStop(0.5, "rgba(246,196,83,0.06)");
    g.addColorStop(1, "rgba(0,0,0,0)");
    sctx.fillStyle = g;
    sctx.fillRect(0,0,w,h);

    for(const st of stars){
      st.y += st.sp * st.z;
      if(st.y > h+10){ st.y = -10; st.x = Math.random()*w; }
      const tw = 0.55 + Math.sin(t + st.tw*6.28)*0.35;
      const alpha = 0.10 + tw*0.45;

      // color drift between purple & gold
      const mix = (Math.sin(t*0.8 + st.tw*10)+1)/2;
      const r = Math.floor(168 + mix*78);
      const gg = Math.floor(85 + mix*111);
      const b = Math.floor(247 - mix*170);

      sctx.beginPath();
      sctx.fillStyle = `rgba(${r},${gg},${b},${alpha})`;
      sctx.arc(st.x, st.y, st.r, 0, Math.PI*2);
      sctx.fill();
    }

    requestAnimationFrame(tick);
  }
  tick();

  /* ====== Initial render ====== */
  refreshPreview();

})();
</script>
