<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="theme-color" content="#120018" />
  <title>Skyes Over London LC — Model & Video Talent Console</title>
  <meta name="description" content="Skyes Over London LC Model & Video Talent Console — apply, set boundaries, sign release, and submit from our site." />
  <meta name="robots" content="index,follow" />

  <!-- Open Graph -->
  <meta property="og:title" content="Skyes Over London LC — Model & Video Talent Console" />
  <meta property="og:description" content="Apply + sign the Model Release + Video Usage Agreement securely from our site." />
  <meta property="og:type" content="website" />

  <style>
    :root{
      --bg0:#07000a;
      --bg1:#0c0014;
      --bg2:#120018;
      --ink:#f6edff;
      --muted: rgba(246,237,255,.72);
      --muted2: rgba(246,237,255,.56);
      --line: rgba(255,255,255,.12);

      --p1:#a855f7;
      --p2:#6d28d9;
      --g1:#f6c453;
      --g2:#f59e0b;

      --ok:#34d399;
      --warn:#fbbf24;
      --bad:#fb7185;

      --shadow: 0 18px 60px rgba(0,0,0,.55);
      --shadow2: 0 12px 30px rgba(0,0,0,.35);

      --r: 18px;
      --r2: 26px;

      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }

    *{ box-sizing:border-box }
    html,body{ height:100% }
    body{
      margin:0;
      font-family: var(--sans);
      color: var(--ink);
      background:
        radial-gradient(900px 520px at 20% 10%, rgba(168,85,247,.22), transparent 60%),
        radial-gradient(900px 520px at 78% 20%, rgba(245,158,11,.18), transparent 62%),
        radial-gradient(1100px 680px at 50% 100%, rgba(109,40,217,.16), transparent 62%),
        linear-gradient(180deg, var(--bg0), var(--bg2));
      overflow-x:hidden;
    }

    /* Starfield canvas */
    #starfield{
      position:fixed; inset:0;
      width:100vw; height:100vh;
      z-index:-3;
      opacity:.85;
    }
    /* Soft glow layer */
    .veil{
      position:fixed; inset:-2px;
      background:
        radial-gradient(700px 420px at 35% 35%, rgba(168,85,247,.12), transparent 70%),
        radial-gradient(900px 520px at 70% 20%, rgba(246,196,83,.08), transparent 70%),
        linear-gradient(180deg, rgba(0,0,0,.18), rgba(0,0,0,.62));
      z-index:-2;
      pointer-events:none;
    }

    /* Cursor aura */
    .cursor-aura{
      position:fixed;
      width:360px; height:360px;
      border-radius:999px;
      pointer-events:none;
      z-index:-1;
      background:
        radial-gradient(circle at center,
          rgba(168,85,247,.20) 0%,
          rgba(246,196,83,.12) 28%,
          rgba(109,40,217,.10) 40%,
          rgba(0,0,0,0) 72%);
      filter: blur(2px);
      transform: translate(-50%,-50%);
      mix-blend-mode: screen;
      opacity:.75;
    }

    /* Layout */
    .wrap{
      max-width: 1320px;
      margin: 0 auto;
      padding: 18px 16px 60px;
    }

    .topbar{
      display:flex;
      gap:14px;
      align-items:center;
      justify-content:space-between;
      padding: 14px 14px;
      border:1px solid var(--line);
      border-radius: var(--r2);
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(0,0,0,.18));
      box-shadow: var(--shadow2);
      backdrop-filter: blur(10px);
      position:sticky;
      top:12px;
      z-index:50;
    }

    .brand{
      display:flex;
      gap:12px;
      align-items:center;
      min-width: 280px;
    }

    .sigil{
      width:44px; height:44px;
      border-radius: 16px;
      background:
        radial-gradient(circle at 30% 30%, rgba(246,196,83,.95), rgba(246,196,83,.10) 55%),
        radial-gradient(circle at 70% 70%, rgba(168,85,247,.85), rgba(168,85,247,.10) 58%),
        linear-gradient(135deg, rgba(255,255,255,.08), rgba(0,0,0,.28));
      box-shadow: 0 18px 40px rgba(0,0,0,.55);
      border:1px solid rgba(255,255,255,.14);
      position:relative;
      overflow:hidden;
    }
    .sigil:after{
      content:"";
      position:absolute; inset:-30%;
      background: conic-gradient(from 180deg, rgba(168,85,247,.0), rgba(168,85,247,.35), rgba(246,196,83,.28), rgba(168,85,247,.0));
      animation: spin 6s linear infinite;
      opacity:.9;
    }
    @keyframes spin{ to{ transform: rotate(360deg) } }

    .brand h1{
      margin:0;
      font-size: 14px;
      letter-spacing:.06em;
      text-transform:uppercase;
      line-height:1.1;
    }
    .brand .sub{
      font-size:12px;
      color: var(--muted);
      margin-top:2px;
    }

    .chiprow{
      display:flex; flex-wrap:wrap;
      gap:8px;
      justify-content:flex-end;
      align-items:center;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 9px 12px;
      border-radius: 999px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.20);
      box-shadow: 0 10px 22px rgba(0,0,0,.30);
      font-size:12px;
      color: var(--muted);
      user-select:none;
    }
    .dot{
      width:8px; height:8px; border-radius:999px;
      background: linear-gradient(180deg, var(--g1), var(--p1));
      box-shadow: 0 0 0 4px rgba(246,196,83,.10), 0 0 20px rgba(168,85,247,.25);
    }

    .btn{
      cursor:pointer;
      border:1px solid rgba(255,255,255,.16);
      background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(0,0,0,.25));
      color: var(--ink);
      border-radius: 14px;
      padding: 10px 12px;
      font-weight:600;
      font-size: 12px;
      letter-spacing:.02em;
      transition: transform .12s ease, border-color .12s ease, background .12s ease;
      box-shadow: 0 14px 28px rgba(0,0,0,.30);
    }
    .btn:hover{ transform: translateY(-1px); border-color: rgba(246,196,83,.35); }
    .btn:active{ transform: translateY(0px); }

    .btnPrimary{
      border:1px solid rgba(246,196,83,.35);
      background:
        radial-gradient(120% 120% at 10% 20%, rgba(246,196,83,.25), transparent 55%),
        radial-gradient(120% 120% at 80% 30%, rgba(168,85,247,.22), transparent 55%),
        linear-gradient(180deg, rgba(0,0,0,.10), rgba(0,0,0,.38));
    }

    .grid{
      display:grid;
      grid-template-columns: 420px 1fr;
      gap: 16px;
      margin-top: 16px;
      align-items:start;
    }
    @media (max-width: 1080px){
      .grid{ grid-template-columns: 1fr; }
      .brand{ min-width: unset; }
    }

    .panel{
      border:1px solid rgba(255,255,255,.12);
      border-radius: var(--r2);
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(0,0,0,.20));
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      overflow:hidden;
    }

    .panelHeader{
      padding: 14px 14px;
      border-bottom: 1px solid rgba(255,255,255,.10);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }
    .panelHeader h2{
      margin:0;
      font-size: 13px;
      letter-spacing:.08em;
      text-transform:uppercase;
      display:flex;
      align-items:center;
      gap:10px;
    }
    .rune{
      width:10px; height:10px;
      border-radius: 3px;
      background: linear-gradient(180deg, var(--p1), var(--g1));
      box-shadow: 0 0 0 4px rgba(168,85,247,.12), 0 0 18px rgba(246,196,83,.18);
      transform: rotate(12deg);
    }

    .panelBody{ padding: 14px 14px; }

    /* Steps */
    .steps{
      display:flex; gap:10px; flex-wrap:wrap;
      padding: 10px 14px 0;
    }
    .step{
      flex:1 1 120px;
      padding: 10px 10px;
      border-radius: 16px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(0,0,0,.18);
      position:relative;
      overflow:hidden;
      cursor:pointer;
      transition: transform .12s ease, border-color .12s ease;
      user-select:none;
      min-width: 130px;
    }
    .step:hover{ transform: translateY(-1px); border-color: rgba(168,85,247,.35); }
    .step.active{ border-color: rgba(246,196,83,.42); background: rgba(0,0,0,.26); }
    .step .k{
      font-size: 11px; color: var(--muted);
      text-transform:uppercase; letter-spacing:.08em;
    }
    .step .t{
      font-size: 12px; margin-top: 4px;
      font-weight:800;
    }
    .step:before{
      content:"";
      position:absolute; inset:-40%;
      background: conic-gradient(from 180deg, rgba(246,196,83,.0), rgba(246,196,83,.22), rgba(168,85,247,.18), rgba(246,196,83,.0));
      opacity:.45;
      transform: rotate(10deg);
      animation: slowspin 12s linear infinite;
      pointer-events:none;
    }
    @keyframes slowspin{ to{ transform: rotate(360deg) } }

    /* Form controls */
    form{ margin:0; }
    .section{ display:none; }
    .section.active{ display:block; animation: fadeIn .18s ease; }
    @keyframes fadeIn{ from{opacity:.3; transform: translateY(4px)} to{opacity:1; transform: translateY(0)} }

    .fieldGrid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    @media (max-width: 720px){
      .fieldGrid{ grid-template-columns: 1fr; }
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-bottom: 10px;
    }
    label{
      font-size: 12px;
      color: var(--muted);
      letter-spacing:.02em;
    }
    input, select, textarea{
      width:100%;
      padding: 10px 10px;
      border-radius: 14px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.22);
      color: var(--ink);
      outline:none;
      font-size: 13px;
      box-shadow: 0 10px 18px rgba(0,0,0,.28);
    }
    textarea{ min-height: 92px; resize: vertical; }
    input::placeholder, textarea::placeholder{ color: rgba(246,237,255,.40); }
    input:focus, select:focus, textarea:focus{ border-color: rgba(246,196,83,.40); }

    .smallNote{
      font-size: 11px;
      color: var(--muted2);
      line-height:1.35;
      margin-top: 4px;
    }

    .pillRow{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top: 6px;
    }
    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 8px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.18);
      color: var(--muted);
      font-size:12px;
      user-select:none;
    }
    .pill input{ width:auto; margin:0; transform: translateY(1px); }

    .divider{
      height:1px;
      background: rgba(255,255,255,.10);
      margin: 12px 0;
    }

    .actions{
      display:flex;
      gap:10px;
      justify-content:space-between;
      align-items:center;
      margin-top: 10px;
      flex-wrap:wrap;
    }
    .leftActions, .rightActions{
      display:flex; gap:10px; flex-wrap:wrap;
      align-items:center;
    }

    /* Preview panel */
    .previewTop{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
    }
    .badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 9px 12px;
      border-radius: 999px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.18);
      color: var(--muted);
      font-size:12px;
    }
    .badge strong{ color: var(--ink); font-family: var(--mono); font-size: 12px; }

    .scrollBox{
      border:1px solid rgba(255,255,255,.12);
      border-radius: var(--r2);
      background: rgba(0,0,0,.18);
      padding: 12px;
      max-height: calc(100vh - 210px);
      overflow:auto;
      box-shadow: 0 14px 28px rgba(0,0,0,.28);
    }
    @media (max-width: 1080px){
      .scrollBox{ max-height: unset; }
    }

    .contract{
      font-family: var(--sans);
      line-height: 1.5;
      color: rgba(246,237,255,.92);
    }
    .contract h3{
      margin: 10px 0 6px;
      font-size: 12px;
      letter-spacing:.10em;
      text-transform:uppercase;
      color: rgba(246,196,83,.92);
    }
    .contract p, .contract li{
      font-size: 12.5px;
      color: rgba(246,237,255,.86);
    }
    .contract ul{ margin: 6px 0 10px 18px; padding:0; }
    .contract .mono{
      font-family: var(--mono);
      font-size: 12px;
      color: rgba(246,237,255,.90);
    }
    .contract .muted{
      color: rgba(246,237,255,.68);
      font-size: 12px;
    }

    /* Glitch title */
    .glitch{
      position:relative;
      display:inline-block;
      font-weight:900;
      letter-spacing:.10em;
      text-transform:uppercase;
      font-size: 12px;
    }
    .glitch:before, .glitch:after{
      content: attr(data-text);
      position:absolute;
      left:0; top:0;
      opacity:.55;
      pointer-events:none;
      clip-path: inset(0 0 0 0);
    }
    .glitch:before{ transform: translate(1px, 0); color: rgba(168,85,247,.85); }
    .glitch:after{ transform: translate(-1px, 0); color: rgba(246,196,83,.75); }
    .glitchPulse{ animation: glitchPulse 5.5s infinite; }
    @keyframes glitchPulse{
      0%, 100%{ clip-path: inset(0 0 0 0); filter:none; }
      22%{ clip-path: inset(10% 0 60% 0); }
      23%{ clip-path: inset(42% 0 20% 0); filter: blur(.2px); }
      24%{ clip-path: inset(2% 0 74% 0); }
      25%{ clip-path: inset(0 0 0 0); filter:none; }
    }

    /* Signature pad */
    .sigWrap{
      border:1px solid rgba(255,255,255,.14);
      border-radius: var(--r2);
      background: rgba(0,0,0,.18);
      padding: 10px;
      box-shadow: 0 14px 28px rgba(0,0,0,.28);
    }
    canvas#sig{
      width:100%;
      height: 180px;
      display:block;
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.04), rgba(0,0,0,.14));
      border:1px dashed rgba(255,255,255,.16);
      cursor: crosshair;
    }
    .sigTools{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top: 10px;
      justify-content:flex-end;
    }

    /* Toast */
    .toast{
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 999;
      background: rgba(0,0,0,.70);
      border:1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      padding: 12px 12px;
      min-width: 260px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      display:none;
    }
    .toast.show{ display:block; animation: pop .18s ease; }
    @keyframes pop{ from{ transform: translateY(6px); opacity:.2 } to{ transform: translateY(0); opacity:1 } }
    .toast .t1{ font-weight:900; letter-spacing:.04em; font-size: 12px; }
    .toast .t2{ color: var(--muted); font-size: 12px; margin-top: 4px; line-height:1.35; }

    /* Success screen */
    .success{
      display:none;
      padding: 18px 14px;
      border-top: 1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.20);
    }
    .success.show{ display:block; }
    .success .big{
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-size: 14px;
    }
    .success .msg{ color: var(--muted); margin-top: 6px; font-size: 12px; line-height:1.4; }

    /* Tiny footer */
    .tinyFooter{
      margin-top: 14px;
      color: rgba(246,237,255,.55);
      font-size: 11px;
      line-height: 1.35;
    }
    a{ color: rgba(246,196,83,.92) }
  </style>

  <!-- jsPDF (client-side PDF generation) -->
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js" defer></script>
</head>

<body>
  <canvas id="starfield"></canvas>
  <div class="veil"></div>
  <div class="cursor-aura" id="aura"></div>

  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="sigil" aria-hidden="true"></div>
        <div>
          <h1>Skyes Over London LC</h1>
          <div class="sub">Model & Video Talent Console • Apply • Set Boundaries • Sign • Submit</div>
        </div>
      </div>

      <div class="chiprow">
        <div class="chip"><span class="dot"></span> Consent-Based • 18+ Only • Client-Safe</div>
        <button class="btn" type="button" id="btnLoad">Load Saved</button>
        <button class="btn" type="button" id="btnSave">Save</button>
        <button class="btn btnPrimary" type="button" id="btnPDF">Download PDF</button>
      </div>
    </div>

    <div class="grid">
      <!-- LEFT: CONSOLE -->
      <div class="panel">
        <div class="panelHeader">
          <h2><span class="rune"></span> <span class="glitch glitchPulse" data-text="Talent Console">Talent Console</span></h2>
          <span class="chip" title="This ID is generated and included with your submission.">
            Contract ID: <span class="mono" id="contractId" style="font-family:var(--mono);color:var(--ink);">—</span>
          </span>
        </div>

        <div class="steps" id="steps">
          <div class="step active" data-step="0"><div class="k">Step 1</div><div class="t">Identity</div></div>
          <div class="step" data-step="1"><div class="k">Step 2</div><div class="t">Project + Pay</div></div>
          <div class="step" data-step="2"><div class="k">Step 3</div><div class="t">Usage + NDA</div></div>
          <div class="step" data-step="3"><div class="k">Step 4</div><div class="t">Consent + Wardrobe</div></div>
          <div class="step" data-step="4"><div class="k">Step 5</div><div class="t">Signature + Submit</div></div>
        </div>

        <div class="panelBody">
          <!-- NETLIFY FORM (do not remove attributes) -->
          <form name="sol-model-console" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" id="theForm">
            <input type="hidden" name="form-name" value="sol-model-console" />
            <p style="display:none;">
              <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
            </p>

            <!-- Hidden computed fields -->
            <input type="hidden" name="contract_id" id="f_contract_id" />
            <input type="hidden" name="submitted_local_time" id="f_time" />
            <input type="hidden" name="signature_dataurl" id="f_sig" />
            <input type="hidden" name="agreement_text_snapshot" id="f_snapshot" />

            <!-- SECTION 0: IDENTITY -->
            <div class="section active" data-sec="0">
              <div class="fieldGrid">
                <div class="field">
                  <label>Legal Name (required)</label>
                  <input name="talent_legal_name" id="talent_legal_name" placeholder="Your legal name" required />
                </div>
                <div class="field">
                  <label>Stage / Model Name (optional)</label>
                  <input name="talent_stage_name" id="talent_stage_name" placeholder="If you use one" />
                </div>
              </div>

              <div class="fieldGrid">
                <div class="field">
                  <label>Date of Birth (18+ required)</label>
                  <input type="date" name="talent_dob" id="talent_dob" required />
                  <div class="smallNote">We may request ID verification prior to booking. We do not knowingly work with minors.</div>
                </div>
                <div class="field">
                  <label>City / State</label>
                  <input name="talent_city_state" id="talent_city_state" placeholder="Phoenix, AZ / Chicago, IL etc." required />
                </div>
              </div>

              <div class="fieldGrid">
                <div class="field">
                  <label>Email</label>
                  <input type="email" name="talent_email" id="talent_email" placeholder="name@email.com" required />
                </div>
                <div class="field">
                  <label>Phone</label>
                  <input name="talent_phone" id="talent_phone" placeholder="(###) ###-####" required />
                </div>
              </div>

              <div class="fieldGrid">
                <div class="field">
                  <label>Address (optional)</label>
                  <input name="talent_address" id="talent_address" placeholder="Street, City, State, Zip" />
                </div>
                <div class="field">
                  <label>Instagram/TikTok/Portfolio Link (preferred)</label>
                  <input name="talent_portfolio" id="talent_portfolio" placeholder="https://..." />
                </div>
              </div>

              <div class="fieldGrid">
                <div class="field">
                  <label>Experience Level</label>
                  <select name="talent_experience" id="talent_experience">
                    <option>Beginner</option>
                    <option>Intermediate</option>
                    <option>Pro</option>
                  </select>
                </div>
                <div class="field">
                  <label>Strengths (select all that apply)</label>
                  <div class="pillRow">
                    <label class="pill"><input type="checkbox" name="strengths" value="Modeling" /> Modeling</label>
                    <label class="pill"><input type="checkbox" name="strengths" value="Talking-Head UGC" /> Talking-Head UGC</label>
                    <label class="pill"><input type="checkbox" name="strengths" value="Acting" /> Acting</label>
                    <label class="pill"><input type="checkbox" name="strengths" value="Dancing" /> Dancing</label>
                    <label class="pill"><input type="checkbox" name="strengths" value="Hosting" /> Hosting</label>
                    <label class="pill"><input type="checkbox" name="strengths" value="Voice" /> Voice</label>
                  </div>
                </div>
              </div>

              <div class="divider"></div>

              <div class="field">
                <label>Emergency Contact (optional)</label>
                <input name="emergency_contact" id="emergency_contact" placeholder="Name + phone" />
              </div>

              <div class="actions">
                <div class="leftActions">
                  <span class="chip"><span class="dot"></span> Your boundaries are respected. No pressure. No surprises.</span>
                </div>
                <div class="rightActions">
                  <button class="btn btnPrimary" type="button" data-next>Next</button>
                </div>
              </div>
            </div>

            <!-- SECTION 1: PROJECT + PAY -->
            <div class="section" data-sec="1">
              <div class="fieldGrid">
                <div class="field">
                  <label>Project / Campaign Name</label>
                  <input name="project_name" id="project_name" placeholder="e.g., Convenience Store Promo / Music Video / Corporate Ad" required />
