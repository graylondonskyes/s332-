# Copy to .env and fill values
MCP_API_TOKEN=changeme_mcp_token
PORT=3003
# Root of repository to serve (optional). Defaults to repo parent.
REPO_ROOT=

# GitHub settings used by /write endpoint
REPO_OWNER=your-org-or-user
REPO_NAME=your-repo-name

# Use either a classic/fine-grained token or GitHub App installation credentials.
GITHUB_TOKEN=ghp_xxxreplace
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Paste a PEM with escaped newlines or use GITHUB_APP_PRIVATE_KEY_BASE64.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=

# Skyegate auth and optional write metering.
SKYEGATE_INTROSPECT_URL=
SKYEGATE_AUD=mcp
SKYE_BILLING_METER_URL=
SKYE_BILLING_API_KEY=
SKYE_BILLING_TIMEOUT_MS=3000

# Optional shared secret checked by .github/workflows/create-pr.yml.
MCP_DISPATCH_SECRET=
